                "svg": "<svg width=\"424\" height=\"26\"><text font-family=\"TypeWriter\" font-size=\"10.0\" font-weight=\"bold\" fill=\"#000000\" fill-opacity=\"1.0\">sau khi claim root -&gt; d\u00f9ng yersinia \u0111\u1ec3 dos v\u1edbi g\u00f3i tin tcn</text></svg>",
